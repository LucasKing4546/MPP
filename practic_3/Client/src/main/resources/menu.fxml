<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.MenuController">
   <children>
      <VBox alignment="CENTER" layoutX="200.0" layoutY="70.0" prefHeight="400.0" prefWidth="600.0" spacing="30.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label text="MENU">
               <font>
                  <Font size="31.0" />
               </font>
            </Label>
            <Button fx:id="startButton" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#handleStrat" text="Start GAME" VBox.vgrow="ALWAYS">
               <font>
                  <Font size="20.0" />
               </font>
            </Button>
            <Button fx:id="checkButton" mnemonicParsing="false" onAction="#handleCheck" text="Check statistics">
               <font>
                  <Font size="20.0" />
               </font>
            </Button>
            <VBox alignment="TOP_CENTER" prefHeight="185.0" prefWidth="600.0" spacing="20.0">
               <children>
                  <Label text="Leaderboard">
                     <font>
                        <Font size="20.0" />
                     </font>
                  </Label>
                  <Label fx:id="top1" text="p1">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <Label fx:id="top2" text="p2">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <Label fx:id="top3" text="p3">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
