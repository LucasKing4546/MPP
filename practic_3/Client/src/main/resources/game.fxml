<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="430.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.GameController">
   <children>
      <VBox alignment="CENTER" layoutX="200.0" layoutY="74.0" prefHeight="433.0" prefWidth="600.0" spacing="40.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label text="Rock, Paper, Scissors">
               <font>
                  <Font size="43.0" />
               </font>
            </Label>
            <Label fx:id="scoreLabel" text="Score: 0 ">
               <font>
                  <Font size="25.0" />
               </font>
            </Label>
            <Label fx:id="drawLabel" layoutX="263.0" layoutY="134.0" text="Draws: 0">
               <font>
                  <Font size="25.0" />
               </font>
            </Label>
            <Label fx:id="lastGuessLabel" text="?">
               <font>
                  <Font size="27.0" />
               </font>
            </Label>
            <HBox alignment="CENTER" prefHeight="413.0" prefWidth="600.0" spacing="60.0">
               <children>
                  <Button fx:id="rockButton" mnemonicParsing="false" onAction="#handleRock" text="Rock">
                     <font>
                        <Font size="22.0" />
                     </font>
                  </Button>
                  <Button fx:id="PaperButton" mnemonicParsing="false" onAction="#handlePaper" text="Paper">
                     <font>
                        <Font size="22.0" />
                     </font>
                  </Button>
                  <Button fx:id="scissorsButton" mnemonicParsing="false" onAction="#handleScissors" text="Scissors">
                     <font>
                        <Font size="22.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
